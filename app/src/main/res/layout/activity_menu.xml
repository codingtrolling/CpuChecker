<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5"
    android:gravity="center"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Cpu Checker"
        android:textColor="#000000"
        android:textSize="26sp"
        android:textStyle="bold"
        android:layout_marginBottom="40dp" />

    <Button android:layout_width="match_parent" android:layout_height="55dp" android:text="CPU CORE DATA" android:layout_marginBottom="12dp" android:onClick="launchCpu" android:textAllCaps="false"/>
    <Button android:layout_width="match_parent" android:layout_height="55dp" android:text="Network Analyzer" android:layout_marginBottom="12dp" android:onClick="launchNetwork" android:textAllCaps="false"/>
    <Button android:layout_width="match_parent" android:layout_height="55dp" android:text="Power &amp; Battery" android:layout_marginBottom="12dp" android:onClick="launchBattery" android:textAllCaps="false"/>
    <Button android:layout_width="match_parent" android:layout_height="55dp" android:text="System Archive" android:layout_marginBottom="12dp" android:onClick="launchSystem" android:textAllCaps="false"/>
    <Button android:layout_width="match_parent" android:layout_height="55dp" android:text="Display &amp; GPU" android:layout_marginBottom="12dp" android:onClick="launchDisplay" android:textAllCaps="false"/>

</LinearLayout>
